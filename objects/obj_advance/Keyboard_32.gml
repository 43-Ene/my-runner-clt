//Ao apertar a barra de espaco durante a cutscene
//Se o jogador ainda estiver na primeira pagina
if(spr_cutscene.image_index == 1)
{
	//A instrucao se movera para estas coordenadas
	x = 14;
	y = 607;
}

//Se o jogador estiver na segunda pagina
if(spr_cutscene.image_index == 2)
{
	//A instrucao se movera para estas coordenadas
	x = 110;
	y = 603;
}

//Se o jogador estiver na terceira pagina
if(spr_cutscene.image_index == 3)
{
	//A instrucao se movera para estas coordenadas
	x = 210;
	y = 603;
}